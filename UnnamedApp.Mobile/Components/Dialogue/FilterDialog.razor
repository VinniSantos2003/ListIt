@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudPaper Class="filter-container">
    <MudStack> 
        <MudStack Row="true">
            <MudButton Class="button-config">A-Z</MudButton>
            <MudButton Class="button-config">Z-A</MudButton>
        </MudStack>
        <MudStack Row="true">
            <MudButton Class="button-config">R$ <MudIcon Icon="@Icons.Material.Filled.ArrowUpward"/></MudButton>
            <MudButton Class="button-config">R$ <MudIcon Icon="@Icons.Material.Filled.ArrowDownward"/></MudButton>
        </MudStack>
        <MudStack Row="true">
            <MudButton Class="button-config">Novo</MudButton>
            <MudButton Class="button-config">Antigo</MudButton>
        </MudStack>
    </MudStack>
    <MudButton Variant="Variant.Filled" Color="Color.Error" >Cancelar</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary">Aplicar</MudButton>

</MudPaper>


