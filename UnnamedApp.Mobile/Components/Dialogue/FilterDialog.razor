@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    private string ActualPage { get; set; } = string.Empty;
    public string FiltroSelecionado { get; set; } = "AZ";

    // Colocar verificação de página,
    // talvez esse filtro ou sort tenha funcionamento diferente dependendo da página ativa

    private void SortAZ()
    {
        Snackbar.Add("Ordenação A>Z aplicada!");
    }



    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
