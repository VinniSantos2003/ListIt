@using UnnamedApp.Mobile.Components.NoRoute
@using UnnamedApp.Mobile.Events
@inherits LayoutComponentBase
<MudLayout>
    <MudThemeProvider />
    <MudPopoverProvider />
    <MudDialogProvider CloseButton="true"/>
    <MudSnackbarProvider />

    <MudMainContent Style="padding-top:0;">
        <CascadingValue Value="@GlobalEventController">
            <div class="page">
                <main class="content-scrollable">
                        @Body
                </main>
                <div class="floating-menu">
                    <FloatingMenu />
                </div>
                <div class="sidebar">
                    <NavMenu />
                </div>
            </div>
        </CascadingValue>
    </MudMainContent>
</MudLayout>


@code{
    private GlobalEventController GlobalEventController = new();
}