@page "/"
@page "/home"
@using UnnamedApp.Mobile.Components.NoRoute

<div id="main-div">
    <div>
        <h1>List It</h1>
    </div>

    <MudPaper Elevation="2" Class="pa-4 rounded-xl">

        <!-- 🔹 Linha do topo (setas + mês/ano) -->
        <div class="d-flex align-center justify-space-between mb-2">

            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                           OnClick="MesAnterior" />

            <div class="d-flex gap-2">

                <!-- Mês -->
                <MudSelect T="int" @bind-Value="mes" Dense="true" Style="width:90px">
                    @foreach (var m in meses)
                    {
                        <MudSelectItem Value="@m">@MesNome(m)</MudSelectItem>
                    }
                </MudSelect>

                <!-- Ano -->
                <MudSelect T="int" @bind-Value="ano" Dense="true" Style="width:90px">
                    @foreach (var a in anos)
                    {
                        <MudSelectItem Value="@a">@a</MudSelectItem>
                    }
                </MudSelect>

            </div>

            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                           OnClick="ProximoMes" />

        </div>

        <MudDivider Class="my-3" />

        <!-- Linha de indicadores -->
        <div class="d-flex justify-space-between text-center texto-ajustado">

            <div>
                <MudText Typo="Typo.caption">Gastos</MudText>
                <MudText Typo="Typo.h6">R$370.00</MudText>
            </div>

            <div>
                <MudText Typo="Typo.caption">Itens Comprados</MudText>
                <MudText Typo="Typo.h6">6</MudText>
            </div>

            <div>
                <MudText Typo="Typo.caption">Limite</MudText>
                <MudText Typo="Typo.h6">-</MudText>
            </div>

        </div>

        <MudDivider Class="my-3" />

        <!-- Linha inferior -->
        <div class="d-flex align-center justify-space-between">

            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.RadioButtonUnchecked" />
                <MudText Typo="Typo.body2">Sem limite definido</MudText>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="px-4"
                       Style="border-radius:20px;">
                Definir Limite
            </MudButton>
        </div>
    </MudPaper>

    <!-- Card azul -->
    <MudPaper Class="pa-4 mb-3 rounded-xl sum-of-wishes-card" Style="background:#1E88E5; color:white;">
        <div class="d-flex justify-space-between align-center">
            <MudText Typo="Typo.h6">Soma dos Desejos</MudText>
            <MudText Typo="Typo.h5">@($"R${SomaDesejos:F2}")</MudText>
        </div>
    </MudPaper>

    <!-- Busca -->
    <MudTextField Placeholder="Buscar lista..."
                  Variant="Variant.Outlined"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Class="mb-3 list-filter"
                  @bind-Value="filtro" />

    <!-- Listas -->
    @foreach (var lista in ListasFiltradas)
    {
        <MudPaper Class="pa-4 mb-3 rounded-xl">

            <div class="d-flex justify-space-between align-center">

                <div>
                    <MudText Typo="Typo.h6">@lista.Nome</MudText>
                    <MudText Typo="Typo.body2">@lista.Descricao</MudText>
                </div>

                <MudText Typo="Typo.h6">
                    @($"R${lista.Total:F2}")
                </MudText>

            </div>

            <MudProgressLinear Value="@lista.Progresso"
                               Class="my-2"
                               Color="Color.Success" />

            <div class="d-flex justify-space-between">

                <MudText Typo="Typo.caption">
                    @($"{lista.Progresso}%")
                </MudText>

                <MudChip T="string">
                    @($"{lista.ItensComprados}/{lista.TotalItens}")
                </MudChip>

            </div>

        </MudPaper>
    }

</div>

@code {
    private int mes = DateTime.Now.Month;
    private int ano = DateTime.Now.Year;

    private List<int> meses = Enumerable.Range(1, 12).ToList();

    private List<int> anos = Enumerable
        .Range(DateTime.Now.Year - 5, 16)
        .ToList();

    private void ProximoMes()
    {
        if (mes == 12)
        {
            mes = 1;
            ano++;
        }
        else
        {
            mes++;
        }
    }

    private void MesAnterior()
    {
        if (mes == 1)
        {
            mes = 12;
            ano--;
        }
        else
        {
            mes--;
        }
    }

    private string MesNome(int m)
    {
        return new DateTime(1, m, 1).ToString("MMM");
    }

    private string filtro = "";

    private List<ListaDesejo> listas = new()
    {
        new ListaDesejo
        {
            Nome = "Comprinhas",
            Descricao = "Roupas e sapatos",
            Total = 320,
            TotalItens = 10,
            ItensComprados = 5
        },
        new ListaDesejo
        {
            Nome = "Casa nova",
            Descricao = "Móveis e decoração",
            Total = 880,
            TotalItens = 5,
            ItensComprados = 1
        }
    };

    private IEnumerable<ListaDesejo> ListasFiltradas =>
        listas.Where(l =>
            string.IsNullOrWhiteSpace(filtro) ||
            (l.Nome?.Contains(filtro, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (l.Descricao?.Contains(filtro, StringComparison.OrdinalIgnoreCase) ?? false)
        );

    private double SomaDesejos => listas.Sum(l => l.Total);

    public class ListaDesejo
    {
        public string Nome { get; set; }
        public string Descricao { get; set; }
        public double Total { get; set; }

        public int TotalItens { get; set; }
        public int ItensComprados { get; set; }

        public int Progresso =>
            TotalItens == 0 ? 0 : (ItensComprados * 100 / TotalItens);
    }
}